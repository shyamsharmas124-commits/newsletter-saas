PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/newsletter-saas

# JWT secrets - use long random strings (e.g. `openssl rand -hex 32`)
JWT_ACCESS_SECRET=replace_me_with_random_string
JWT_REFRESH_SECRET=replace_me_with_a_different_random_string

# Token lifetimes
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

PAYMENT_SECRET=any_long_random_string_you_choose